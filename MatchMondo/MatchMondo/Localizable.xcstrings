            "value": "Gefällt dir MatchMondo?"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "MatchMondo가 마음에 드시나요?"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هل تستمتع بـ MatchMondo؟"
          }
        },
        "es-ES": {
