    "Enjoying MatchMondo?": {
      "comment": "App review alert title",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "MatchMondoはいかがですか？"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Disfrutas MatchMondo?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous aimez MatchMondo ?"
          }
        },
        "pt-BR": {
