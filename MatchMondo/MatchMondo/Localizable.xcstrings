    "Or we can donate for you — just Venmo @busselle and we'll pass along the donation to Genesis Oakland.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "代わりに寄付することもできます。Venmo @busselle にお送りいただければ、Genesis Oaklandにお届けします。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "O podemos donar por ti — solo haz Venmo a @busselle y pasaremos la donación a Genesis Oakland."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous pouvons aussi donner à votre place — envoyez simplement un Venmo à @busselle et nous transmettrons le don à Genesis Oakland."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ou podemos doar por você — basta usar o Venmo @busselle e repassaremos a doação ao Genesis Oakland."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Oder wir spenden für dich — einfach per Venmo an @busselle und wir leiten die Spende an Genesis Oakland weiter."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "저희가 대신 기부해 드릴 수도 있습니다 — Venmo @busselle로 보내주시면 Genesis Oakland에 전달해 드리겠습니다."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أو يمكننا التبرع نيابةً عنك — فقط أرسل عبر Venmo إلى @busselle وسنحوّل التبرع إلى Genesis Oakland."
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "O podemos donar por ti — simplemente hazlo por Venmo a @busselle y nosotros haremos llegar la donación a Genesis Oakland."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "O possiamo donare per te — manda un Venmo a @busselle e gireremo la donazione a Genesis Oakland."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "或者我们可以代您捐款——只需 Venmo @busselle，我们会将捐款转交给 Genesis Oakland。"
          }
