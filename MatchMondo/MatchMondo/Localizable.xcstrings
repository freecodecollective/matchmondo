    "A warning for unsporting behavior, dissent, persistent fouling, time-wasting, not respecting required distance at free kicks/corners, or entering/leaving the field without permission." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إنذار بسبب السلوك غير الرياضي، أو الاعتراض، أو المخالفات المتكررة، أو إضاعة الوقت، أو عدم احترام المسافة القانونية عند الركلات الحرة/الركنيات، أو الدخول إلى الملعب أو مغادرته دون إذن."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eine Verwarnung für unsportliches Verhalten, Meckern, wiederholtes Foulspiel, Zeitspiel, Nichteinhalten des Abstands bei Freistößen/Ecken oder unerlaubtes Betreten/Verlassen des Feldes."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una advertencia por conducta antideportiva, protestas, faltas reiteradas, pérdida de tiempo, no respetar la distancia en tiros libres/córners, o entrar/salir del campo sin permiso."
          }
        },
        "es-ES" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Amonestación por conducta antideportiva, protestas, faltas reiteradas, pérdida de tiempo, no respetar la distancia en faltas/córneres, o entrar/salir del campo sin permiso."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avertissement pour comportement antisportif, contestation, fautes répétées, perte de temps, non-respect des distances sur coup franc/corner, ou entrée/sortie du terrain sans autorisation."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un ammonimento per comportamento antisportivo, proteste, falli ripetuti, perdita di tempo, mancato rispetto della distanza su punizioni/calcoli d'angolo, o ingresso/uscita dal campo senza autorizzazione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "非スポーツマン行為、異議、繰り返しの反則、時間稼ぎ、フリーキック/コーナーキックでの距離不遵守、無断でのフィールドへの出入りに対する警告。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "비신사적 행위, 이의 제기, 반복 파울, 시간 낭비, 프리킥/코너킥 거리 미준수, 무단 입퇴장에 대한 경고."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uma advertência por comportamento antidesportivo, contestação, faltas repetidas, perda de tempo, não respeitar a distância em cobranças de falta/escanteio, ou entrar/sair do campo sem permissão."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "对非体育行为、异议、持续犯规、拖延时间、任意球/角球不保持规定距离或未经允许进出场地的警告。"
          }
        }
      }
    },
