    "Have an idea to make MatchMondo better? We'd love to hear it.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "MatchMondoをもっと良くするアイデアはありますか？ぜひお聞かせください。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Tienes una idea para mejorar MatchMondo? Nos encantaría escucharla."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une idée pour améliorer MatchMondo ? Nous sommes à l'écoute."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Tem uma ideia para melhorar o MatchMondo? Adoraríamos ouvir."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Hast du eine Idee, wie MatchMondo besser werden kann? Wir freuen uns darauf."
